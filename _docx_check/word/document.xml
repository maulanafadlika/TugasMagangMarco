crosoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 w16se w16cid w16 w16cex w16sdtdh wp14"><w:body><w:p w14:paraId="3C4C32B5" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>LAPORAN HARIAN MAGANG</w:t></w:r></w:p><w:p w14:paraId="4E4B10AA" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>Implementasi Fitur PM pada Transaksi Project</w:t></w:r></w:p><w:p w14:paraId="7FC4CC59" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"/><w:p w14:paraId="2DA4F75C" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>Tanggal: 06 April 2026</w:t></w:r></w:p><w:p w14:paraId="52415D3A" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"/><w:p w14:paraId="5E8E0269" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>1. Tujuan Pekerjaan</w:t></w:r></w:p><w:p w14:paraId="47081892" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>1. Menambahkan data PM (Project Manager) pada transaksi Project.</w:t></w:r></w:p><w:p w14:paraId="7178CB14" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>2. Menambahkan dukungan backend untuk field PM pada proses Add dan Edit Project.</w:t></w:r></w:p><w:p w14:paraId="08796A9F" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>3. Menyediakan API dropdown PM dari tabel users.</w:t></w:r></w:p><w:p w14:paraId="46E3B956" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>4. Melakukan perubahan database pada tabel public.pm_project untuk menyimpan PM terpilih.</w:t></w:r></w:p><w:p w14:paraId="15CD3650" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"/><w:p w14:paraId="0564FF40" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>2. Requirement Tugas</w:t></w:r></w:p><w:p w14:paraId="4DD5955D" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>1. Pada list Project, ditampilkan kolom baru: PM.</w:t></w:r></w:p><w:p w14:paraId="1B93DFD1" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>2. Pada form Add Project, ditambahkan input PM berupa dropdown.</w:t></w:r></w:p><w:p w14:paraId="3B5AD220" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>3. Pada form Edit Project, ditambahkan input PM berupa dropdown.</w:t></w:r></w:p><w:p w14:paraId="664A03C9" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>4. Data dropdown PM diambil dari query:</w:t></w:r></w:p><w:p w14:paraId="0F7C739A" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t xml:space="preserve">   SELECT * FROM public.users</w:t></w:r></w:p><w:p w14:paraId="1CE4BB2D" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t xml:space="preserve">   WHERE group_id LIKE '%PM'</w:t></w:r></w:p><w:p w14:paraId="69B90D04" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t xml:space="preserve">   ORDER BY name ASC;</w:t></w:r></w:p><w:p w14:paraId="45BF7F14" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>5. Tabel yang diubah:</w:t></w:r></w:p><w:p w14:paraId="07B340EA" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t xml:space="preserve">   ALTER TABLE public.pm_project ADD COLUMN pm_id character varying(30);</w:t></w:r></w:p><w:p w14:paraId="3213974D" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>6. Inisialisasi data existing:</w:t></w:r></w:p><w:p w14:paraId="01070C38" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t xml:space="preserve">   UPDATE public.pm_project SET pm_id = created_by;</w:t></w:r></w:p><w:p w14:paraId="07D265EB" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"/><w:p w14:paraId="6A4BDC03" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>3. Perubahan Database (pgAdmin)</w:t></w:r></w:p><w:p w14:paraId="07C98047" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>Lokasi: public.pm_project</w:t></w:r></w:p><w:p w14:paraId="49B2C96E" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"/><w:p w14:paraId="20928F07" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>Perintah yang dijalankan:</w:t></w:r></w:p><w:p w14:paraId="750E6BFF" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>ALTER TABLE public.pm_project</w:t></w:r></w:p><w:p w14:paraId="1CC6BF96" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:lastRenderedPageBreak/><w:t>ADD COLUMN IF NOT EXISTS pm_id character varying(30);</w:t></w:r></w:p><w:p w14:paraId="081D1913" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"/><w:p w14:paraId="3F249FEE" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>UPDATE public.pm_project</w:t></w:r></w:p><w:p w14:paraId="6B6EBDEC" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>SET pm_id = created_by</w:t></w:r></w:p><w:p w14:paraId="442F236C" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>WHERE pm_id IS NULL;</w:t></w:r></w:p><w:p w14:paraId="3780826D" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"/><w:p w14:paraId="3CD690BF" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>Verifikasi:</w:t></w:r></w:p><w:p w14:paraId="3D0631B3" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>SELECT id, created_by, pm_id</w:t></w:r></w:p><w:p w14:paraId="68A75A1E" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>FROM public.pm_project</w:t></w:r></w:p><w:p w14:paraId="6665B7E7" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>LIMIT 20;</w:t></w:r></w:p><w:p w14:paraId="107C71F5" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"/><w:p w14:paraId="7537D597" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>Hasil:</w:t></w:r></w:p><w:p w14:paraId="6AD02448" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>1. Kolom pm_id berhasil ditambahkan.</w:t></w:r></w:p><w:p w14:paraId="66666A52" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>2. Data pm_id berhasil terisi dari created_by.</w:t></w:r></w:p><w:p w14:paraId="4ADE3839" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"/><w:p w14:paraId="406E5A11" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>4. Perubahan Backend</w:t></w:r></w:p><w:p w14:paraId="6D6A486D" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>File yang diubah:</w:t></w:r></w:p><w:p w14:paraId="638DFB5D" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>1. src/models/project/index.js</w:t></w:r></w:p><w:p w14:paraId="31C6698B" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>2. src/services/project/index.js</w:t></w:r></w:p><w:p w14:paraId="5E82AFE3" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>3. src/utils/validator/project/index.js</w:t></w:r></w:p><w:p w14:paraId="30DEAF23" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>4. src/models/user/index.js</w:t></w:r></w:p><w:p w14:paraId="77DC11EB" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>5. src/services/user/index.js</w:t></w:r></w:p><w:p w14:paraId="28367874" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>6. src/modules/user/index.js</w:t></w:r></w:p><w:p w14:paraId="3E279116" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>7. src/router/user/index.js</w:t></w:r></w:p><w:p w14:paraId="08B9FAA4" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"/><w:p w14:paraId="2BDDD53A" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>5. Catatan Coding Lama dan Baru</w:t></w:r></w:p><w:p w14:paraId="45E3A737" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>A. src/models/project/index.js</w:t></w:r></w:p><w:p w14:paraId="1D90CC3D" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>- Lama:</w:t></w:r></w:p><w:p w14:paraId="06410CBA" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t xml:space="preserve">  1. Query list project belum mengambil pm_id dan pm_name.</w:t></w:r></w:p><w:p w14:paraId="6477CF68" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:lastRenderedPageBreak/><w:t xml:space="preserve">  2. Insert project belum menyimpan pm_id.</w:t></w:r></w:p><w:p w14:paraId="742DBB8D" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t xml:space="preserve">  3. Update project belum mengubah pm_id.</w:t></w:r></w:p><w:p w14:paraId="569F2872" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>- Baru:</w:t></w:r></w:p><w:p w14:paraId="4455EE9C" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t xml:space="preserve">  1. Menambahkan p.pm_id dan upm.name AS pm_name pada query list.</w:t></w:r></w:p><w:p w14:paraId="02136344" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t xml:space="preserve">  2. Menambahkan LEFT JOIN users upm ON p.pm_id = upm.id.</w:t></w:r></w:p><w:p w14:paraId="267B062A" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t xml:space="preserve">  3. Menambahkan kolom pm_id pada INSERT INTO pm_project.</w:t></w:r></w:p><w:p w14:paraId="481F0A94" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t xml:space="preserve">  4. Menambahkan set pm_id pada UPDATE pm_project.</w:t></w:r></w:p><w:p w14:paraId="2BD64367" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"/><w:p w14:paraId="3CE978FC" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>B. src/services/project/index.js</w:t></w:r></w:p><w:p w14:paraId="3A18589A" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>- Lama:</w:t></w:r></w:p><w:p w14:paraId="089277AE" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t xml:space="preserve">  1. Payload store dan update belum membawa field pm_id.</w:t></w:r></w:p><w:p w14:paraId="60EB7E0E" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>- Baru:</w:t></w:r></w:p><w:p w14:paraId="1FDA9DBC" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t xml:space="preserve">  1. Store: pm_id diisi dari bodyRequest.pm_id atau fallback ke created_by.</w:t></w:r></w:p><w:p w14:paraId="1982D960" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t xml:space="preserve">  2. Update: pm_id diisi dari bodyRequest.pm_id atau data sebelumnya.</w:t></w:r></w:p><w:p w14:paraId="03969CD1" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"/><w:p w14:paraId="139A5869" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>C. src/utils/validator/project/index.js</w:t></w:r></w:p><w:p w14:paraId="2B7637CF" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t>- Lama:</w:t></w:r></w:p><w:p w14:paraId="67689E25" w14:textId="77777777" w:rsidR="00D4514D" w:rsidRDefault="00D4514D"><w:r><w:t xml:space="preserve">  1. Validator create dan update belum memiliki validasi pm_id.</w:t></w:r></w:p><w:p w14:paraId=